<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Nursing Smart Prep</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="flex h-screen">

  <div class="w-64 bg-blue-900 text-white p-4">
    <h1 class="text-2xl font-bold mb-6">Nursing Prep</h1>
    <ul class="space-y-3">
      <li><button onclick="showPage('dashboard')">Dashboard</button></li>
      <li><button onclick="showPage('subjects')">Subjects</button></li>
      <li><button onclick="showPage('videos')">Videos</button></li>
      <li><button onclick="showPage('notes')">Notes</button></li>
      <li><button onclick="showPage('quiz')">Quiz</button></li>
    </ul>
  </div>

  <div class="flex-1">
    <div class="bg-white shadow p-4 flex justify-between">
      <input class="border p-2 w-1/2" placeholder="Search..." />
      <div>👤 User</div>
    </div>

    <div class="p-6">

      <div id="dashboard" class="page">
        <h2 class="text-2xl font-bold mb-4">Dashboard</h2>
        <div class="grid grid-cols-3 gap-4">
          <div class="bg-white p-4 shadow">Progress: 40%</div>
          <div class="bg-white p-4 shadow">Streak: 5 days</div>
          <div class="bg-white p-4 shadow">Study Hours: 12h</div>
        </div>
      </div>

      <div id="subjects" class="page hidden">
        <h2 class="text-xl font-bold mb-4">Subjects</h2>
        <div class="grid grid-cols-3 gap-4">
          <div class="bg-white p-4 shadow">Anatomy</div>
          <div class="bg-white p-4 shadow">Physiology</div>
          <div class="bg-white p-4 shadow">Pharmacology</div>
        </div>
      </div>

      <div id="videos" class="page hidden">
        <h2 class="text-xl font-bold mb-4">Videos</h2>
        <input id="videoUrl" class="border p-2 w-1/2" placeholder="Paste YouTube link" />
        <button onclick="addVideo()" class="bg-blue-600 text-white p-2 ml-2">Add</button>
        <div id="videoList" class="mt-4"></div>
      </div>

      <div id="notes" class="page hidden">
        <h2 class="text-xl font-bold mb-4">Notes</h2>
        <textarea id="noteInput" class="w-full h-40 border p-2"></textarea>
        <button onclick="saveNote()" class="bg-green-600 text-white p-2 mt-2">Save</button>
        <div id="notesList" class="mt-4"></div>
      </div>

      <div id="quiz" class="page hidden">
        <h2 class="text-xl font-bold mb-4">Quiz</h2>
        <div id="questionBox"></div>
        <button onclick="submitQuiz()" class="bg-blue-600 text-white p-2 mt-4">Submit</button>
        <div id="result" class="mt-4 font-bold"></div>
      </div>

    </div>
  </div>
</div>

<script>
function showPage(page) {
  document.querySelectorAll(".page").forEach(p => p.classList.add("hidden"));
  document.getElementById(page).classList.remove("hidden");
}

function addVideo() {
  const url = document.getElementById("videoUrl").value;
  const embed = url.replace("watch?v=", "embed/");
  document.getElementById("videoList").innerHTML +=
    `<iframe class="w-full h-60 mt-4" src="${embed}" allowfullscreen></iframe>`;
}

function saveNote() {
  const text = document.getElementById("noteInput").value;
  const div = document.createElement("div");
  div.className = "bg-white p-3 shadow mt-2";
  div.innerText = text;
  document.getElementById("notesList").appendChild(div);
}

const questions = [
  { q: "Heart pumps?", options: ["Blood","Air","Water"], answer: 0 },
  { q: "Normal temp?", options: ["37C","50C","10C"], answer: 0 }
];

let userAnswers = [];

function loadQuiz() {
  const box = document.getElementById("questionBox");
  questions.forEach((q,i)=>{
    let html = `<p>${q.q}</p>`;
    q.options.forEach((opt,j)=>{
      html += `<label><input type="radio" name="q${i}" onclick="userAnswers[${i}]=${j}"> ${opt}</label><br>`;
    });
    box.innerHTML += html + "<br>";
  });
}

function submitQuiz() {
  let score = 0;
  questions.forEach((q,i)=>{
    if(userAnswers[i]===q.answer) score++;
  });
  document.getElementById("result").innerText = "Score: "+score;
}

loadQuiz();
</script>

</body>
</html>
